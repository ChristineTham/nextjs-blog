{
  "name": "nextjs-blog",
  "version": "0.2.0",
  "private": true,
  "author": {
    "name": "Chris Tham",
    "email": "chris.tham@hellotham.com",
    "url": "https://hellotham.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChristineTham/nextjs-blog.git"
  },
  "scripts": {
    "dev": "env NODE_OPTIONS=--max_old_space_size=8192 next dev --webpack",
    "build": "env NODE_OPTIONS=--max_old_space_size=8192 next build --webpack",
    "start": "next start",
    "type-check": "tsc --pretty --noEmit",
    "format": "prettier --write .",
    "eslint": "eslint .",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test-all": "pnpm lint && pnpm type-check && pnpm test"
  },
  "prettier": {
    "printWidth": 100,
    "arrowParens": "always",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "semi": false
